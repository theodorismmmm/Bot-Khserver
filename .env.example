# Discord bot token (from Discord Developer Portal)
TOKEN=your_discord_bot_token_here

# ID of the private admin channel where Amazon Gift Card codes will be sent
ADMIN_CHANNEL_ID=your_admin_channel_id_here

# Role ID allowed to use /grant and /removegrant
GRANT_MANAGER_ROLE_ID=your_grant_manager_role_id_here

# Optional comma-separated Discord user IDs allowed to use /grant and /removegrant
# Add @imsosickofit's Discord user ID here to grant manager permission
# Replace these example IDs with real Discord user IDs from your server
GRANT_MANAGER_USER_IDS=123456789012345678,987654321098765432

# Optional role ID automatically added/removed by /grant and /removegrant
PRO_ROLE_ID=your_kahack_pro_role_id_here

# Shortcut shown to users when they run /claim (default: https://www.icloud.com/shortcuts/324c1e4c47824fbbbc36c48b0f7143f0)
CLAIM_SHORTCUT_LINK=https://www.icloud.com/shortcuts/324c1e4c47824fbbbc36c48b0f7143f0
